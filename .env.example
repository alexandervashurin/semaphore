# Пример .env файла для локальной разработки
#
# ВАЖНО: Для PostgreSQL и MySQL необходимо использовать SEMAPHORE_DB_URL
# Отдельные переменные SEMAPHORE_DB_HOST, SEMAPHORE_DB_USER и т.д. НЕ работают!

# ============================================================================
# ВАРИАНТ 1: SQLite (по умолчанию, рекомендуется для тестирования)
# ============================================================================
SEMAPHORE_DB_DIALECT=sqlite
SEMAPHORE_DB_PATH=/tmp/semaphore.db
# SEMAPHORE_DB_URL=sqlite:///tmp/semaphore.db

# ============================================================================
# ВАРИАНТ 2: PostgreSQL (рекомендуется для продакшена)
# ============================================================================
# Раскомментируйте для использования PostgreSQL:
# SEMAPHORE_DB_DIALECT=postgres
# SEMAPHORE_DB_URL=postgres://semaphore:semaphore_pass@localhost:5432/semaphore
#
# Или через Docker (порт 5433):
# SEMAPHORE_DB_URL=postgres://semaphore:semaphore_pass@localhost:5433/semaphore
#
# Для демо-окружения с готовыми данными:
# SEMAPHORE_DB_URL=postgres://semaphore:semaphore123@localhost:5432/semaphore

# ============================================================================
# ВАРИАНТ 3: MySQL
# ============================================================================
# Раскомментируйте для использования MySQL:
# SEMAPHORE_DB_DIALECT=mysql
# SEMAPHORE_DB_URL=mysql://semaphore:semaphore_pass@localhost:3306/semaphore

# ============================================================================
# УСТАРЕВШИЕ ПЕРЕМЕННЫЕ (НЕ ИСПОЛЬЗУЮТСЯ!)
# ============================================================================
# Следующие переменные НЕ работают в Rust версии:
# - SEMAPHORE_DB_HOST
# - SEMAPHORE_DB_PORT
# - SEMAPHORE_DB_USER
# - SEMAPHORE_DB_PASS
# - SEMAPHORE_DB_NAME
# Используйте SEMAPHORE_DB_URL вместо них!

# ============================================================================
# HTTP сервер
# ============================================================================
SEMAPHORE_TCP_ADDRESS=0.0.0.0:3000
SEMAPHORE_WEB_PATH=./web/public

# ============================================================================
# JWT секрет (обязательно измените для продакшена!)
# ============================================================================
# SEMAPHORE_JWT_SECRET=your-secure-random-string-at-least-32-chars

# ============================================================================
# Логирование
# ============================================================================
RUST_LOG=info
# Варианты: error, warn, info, debug, trace

# ============================================================================
# Временная директория
# ============================================================================
SEMAPHORE_TMP_PATH=/tmp/semaphore

# ============================================================================
# HA режим (High Availability) - опционально
# ============================================================================
# SEMAPHORE_HA_ENABLE=false
# SEMAPHORE_HA_REDIS_HOST=localhost
# SEMAPHORE_HA_REDIS_PORT=6379

# ============================================================================
# LDAP - опционально
# ============================================================================
# SEMAPHORE_LDAP_ENABLE=false
# SEMAPHORE_LDAP_SERVER=ldap://localhost:389

# ============================================================================
# TOTP (двухфакторная аутентификация) - опционально
# ============================================================================
# SEMAPHORE_AUTH_TOTP_ENABLE=false
# SEMAPHORE_AUTH_TOTP_ALLOW_RECOVERY=true
